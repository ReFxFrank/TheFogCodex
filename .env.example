# ---- Database (Postgres) ----
# Local example: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql://fog:fogpass@127.0.0.1:5432/fogcodex

# ---- Auth.js (NextAuth v5) ----
# Generate a secret with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=replace-with-a-long-random-string
# Set to true when self-hosting behind a proxy / on a bare server.
AUTH_TRUST_HOST=true

# OAuth providers — create apps and paste the credentials.
# GitHub:  https://github.com/settings/developers  (callback: <url>/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Google:  https://console.cloud.google.com/apis/credentials  (callback: <url>/api/auth/callback/google)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Staff ----
# Comma-separated emails auto-promoted on OAuth sign-in. Owner is the top
# role (outranks admins). Auto-promotion only applies to verified OAuth
# logins; promote an email/password account directly in the DB instead:
#   UPDATE "user" SET role='owner' WHERE email='you@example.com';
# (Email/password sign-up always works even with no OAuth configured.)
STAFF_OWNER_EMAILS=
STAFF_ADMIN_EMAILS=

# ---- Cloudflare cache purge (optional; used by `npm run cache:purge` / deploy) ----
# API token with the "Cache Purge" permission for this zone, and the Zone ID.
CF_API_TOKEN=
CF_ZONE_ID=

# ---- Search engine verification (optional) ----
# Codes from Google Search Console / Bing Webmaster Tools' "HTML tag" method.
# These render a verification <meta> tag at build time — set then rebuild.
# (The DNS-record method needs no rebuild and is usually easier.)
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

